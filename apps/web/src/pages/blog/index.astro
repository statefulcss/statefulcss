---
import { getCollection } from "astro:content";

import Layout from "@layouts/Layout.astro";
import { getOgImagePath } from "@og/templates";
import { comparePostsByDate, getBlogPostPath, getCollectionPageSchema, getReadingTime } from "@utils/content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(comparePostsByDate);
const title = "Blog";
const description = "Articles and updates from Stateful CSS.";
---

<Layout
	title={title}
	description={description}
	image={getOgImagePath("/blog/", { index: true })}
	schema={getCollectionPageSchema("/blog/", title, description)}
>
	<main>
		<h1>Blog Home</h1>
		<ul>
			{
				posts.map((post) => (
					<li>
						<a href={getBlogPostPath(post)}>{post.data.title}</a>
						<p>{post.data.description}</p>
						<time datetime={post.data.publishedAt.toISOString()}>
							{post.data.publishedAt.toLocaleDateString("en", {
								day: "numeric",
								month: "long",
								year: "numeric",
							})}
						</time>
						<span>{getReadingTime(post.body).text}</span>
					</li>
				))
			}
		</ul>
	</main>
</Layout>
