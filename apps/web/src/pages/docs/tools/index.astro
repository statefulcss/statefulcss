---
import { getCollection } from "astro:content";

import Layout from "@layouts/Layout.astro";
import {
	compareByOrderAndTitle,
	docsSections,
	getCollectionPageSchema,
	getDocsEntryPath,
} from "@utils/content";

const section = docsSections.tools;
const entries = (await getCollection("docsTools", ({ data }) => !data.draft)).sort(compareByOrderAndTitle);
---

<Layout
	title={section.title}
	description={section.description}
	schema={getCollectionPageSchema(section.path, section.title, section.description)}
>
	<main>
		<h1>{section.title}</h1>
		<ul>
			{
				entries.map((entry) => (
					<li>
						<a href={getDocsEntryPath("tools", entry)}>{entry.data.title}</a>
						<p>{entry.data.description}</p>
					</li>
				))
			}
		</ul>
	</main>
</Layout>
