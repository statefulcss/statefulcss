{
	"name": "@statefulcss/stylelint-plugin",
	"version": "0.0.0",
	"type": "module",
	"license": "MIT",
	"description": "Stylelint plugin for Stateful CSS",
	"author": {
		"name": "Ömer Balyali",
		"email": "git@omerbalyali.com",
		"url": "https://omerbalyali.com"
	},
	"homepage": "https://statefulcss.com",
	"keywords": [
		"stylelint",
		"plugin",
		"css",
		"stateful-css"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/statefulcss/statefulcss.git",
		"directory": "packages/stylelint-plugin"
	},
	"bugs": {
		"url": "https://github.com/statefulcss/statefulcss/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "eslint --max-warnings 0",
		"check-types": "tsc --noEmit"
	},
	"peerDependencies": {
		"stylelint": "^17.0.0"
	},
	"devDependencies": {
		"@repo/eslint-config": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"eslint": "^9.39.3",
		"stylelint": "^17.6.0",
		"tsup": "^8.4.0",
		"typescript": "^5.9.3",
		"vitest": "^4.1.3"
	}
}
