{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**"]
		},
		"lint": {},
		"transit": {
			"dependsOn": ["^transit"]
		},
		"check-types": {
			"dependsOn": ["transit"]
		},
		"test": {},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
